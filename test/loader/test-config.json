{
  "MODEL_NAME": "gidion_translate_nep_en",
  "MODEL_DIR": "checkpoints/gidion_translate_nep_en",
  "TOKENIZER_PATH": "configs/tokenizers/my-custom-nepali-tokenizer.json",
  "TRAIN_FILE_PATH": "sample-data/train.txt",
  "VAL_FILE_PATH": "sample-data/val.txt",
  "MEMORY_PATH": "memory/gidion_translate_nep_en_memory",
  "LOG_FILE_NAME": "gidion_translate_nep_en.csv",
  "GRADIENT_NORM_LOG_PATH": "logs/gidion_v4_test_v1_grads.csv",

  "d_model": 128,
  "vocab_size": 32000,
  "max_seq_len": 128,
  "dropout_rate": 0.1,

  "memory_encoder": {
    "num_layers": 2,
    "num_heads": 8,
    "ff_hidden_config": [512],
    "num_memory_slots": 4
  },

  "decoder": {
    "num_layers": 4,
    "num_heads": 4,
    "ff_hidden_config": [512]
  },

  "EPOCHS": 3,
  "BATCH_SIZE": 2,
  "CHUNK_SIZE_CHARS": 5000000,
  "OVERLAP_LEN_TOKENS": 32,
  "GRADIENT_ACCUMULATION_STEPS": 16,

  "PEAK_LEARNING_RATE": 3e-04,
  "MIN_LEARNING_RATE": 1e-05,
  "WARMUP_STEPS": 1000,
  "TOTAL_DECAY_STEPS": 200000,

  "CLIP_THRESHOLD": 1.0,
  "ADAM_BETA1": 0.9,
  "ADAM_BETA2": 0.95,
  "WEIGHT_DECAY": 0.00,

  "LABEL_SMOOTHING": 0.0,

  "EVAL_EVERY_N_STEPS": 10,
  "SAVE_EVERY_N_STEPS": 10,
  "LOG_EVERY_N_STEPS": 10,

  "ENABLE_GRL": false,
  "GRL_EVERY_N_OPTIMIZER_STEPS": 2000,
  "GRL_PARAMS": {
    "alpha": 0.001,
    "reinforce_baseline_alpha": 0.95,
    "gen_batch_size": 4,
    "gen_max_len": 64,
    "prompts": [
      "In a startling finding,",
      "The purpose of this project is to"
    ],
    "sampling_temp": 0.9,
    "stop_words": null,
    "top_k": 50,
    "top_p": 0
  },

  "RANDOM_SEED": 42,
  "model_dtype": "float32",
  "resume_training": true,
  "PROMPT_TEMPLATES_PATH": "configs/prompt_templates.json",

  "model": {
    "num_memory_streams": 3
  },

  "total_steps": 0,
  "best_val_loss": "Inf",
  "last_trained_epoch": 0,

  "optimizer_state": {
    "t": 0,
    "lr": 0.0,
    "weight_decay": 0.01,
    "beta1": 0.9,
    "beta2": 0.95,
    "epsilon": 1e-08
  }
}