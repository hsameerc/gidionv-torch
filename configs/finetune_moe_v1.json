{
  "MODEL_NAME": "gidion_moe_v1_finetune",
  "MODEL_DIR": "research/models/gidion_moe_v1_finetune",
  "TOKENIZER_PATH": "configs/tokenizers/bpe_v2_50200_vocab.json",
  "TRAINING_TYPE": "finetune",
  "TRAINING_SOURCE": "online",
  "MODEL_ARCHITECTURE": "moe",
  "LOG_FILE_NAME": "gidion_moe_v1_finetune.csv",
  "PROMPT_TEMPLATES_PATH": "configs/prompt_templates.json",

  "d_model": 512,
  "vocab_size": 50200,
  "max_seq_len": 512,
  "max_context_len": 512,
  "dropout_rate": 0.1,
  "tie_weights": true,
  "model_dtype": "float32",

  "memory_encoder": {
    "num_layers": 2,
    "num_heads": 8,
    "ff_hidden_config": [1024],
    "num_memory_slots": 4
  },

  "decoder": {
    "num_layers": 8,
    "num_heads": 8,
    "ff_hidden_config": [1024, 1024]
  },

  "model": {
    "num_memory_streams": 4
  },

  "EPOCHS": 5,
  "BATCH_SIZE": 4,
  "GRADIENT_ACCUMULATION_STEPS": 8,
  "NUM_WORKERS": 1,
  "use_amp": true,

  "PEAK_LEARNING_RATE": 1e-4,
  "MIN_LEARNING_RATE": 1e-5,
  "WARMUP_STEPS": 100,
  "TOTAL_DECAY_STEPS": 10000,

  "CLIP_THRESHOLD": 1.0,
  "ADAM_BETA1": 0.9,
  "ADAM_BETA2": 0.95,
  "WEIGHT_DECAY": 0.01,

  "EVAL_EVERY_N_STEPS": 200,
  "SAVE_EVERY_N_STEPS": 500,
  "LOG_EVERY_N_STEPS": 10,

  "RANDOM_SEED": 42,
  "resume_training": true,
  "val_max_samples": 50
}
